# Copie para .env e ajuste o que precisar.
NODE_ENV=development
PORT=3334

# Postgres e Redis do docker-compose deste repositório.
DATABASE_URL=postgresql://auth:auth@localhost:5434/auth?schema=public
REDIS_URL=redis://localhost:6380

# Troque por um segredo forte (>= 32 caracteres) em produção.
JWT_SECRET=desenvolvimento-troque-isto-por-um-segredo-bem-grande
